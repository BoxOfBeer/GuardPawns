<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <AssemblyName>SpaceDNA</AssemblyName>
    <RootNamespace>SpaceDNA</RootNamespace>
    <Product>SpaceDNA</Product>
    <AssemblyTitle>SpaceDNA</AssemblyTitle>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>
  <ItemGroup>
    <Content Include="Shaders\planet_vertex.glsl" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="Shaders\planet_fragment.glsl" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="lang_ru.json" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="lang_en.json" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="planet_config.json" CopyToOutputDirectory="PreserveNewest" />
    <PackageReference Include="ImGui.NET" Version="1.91.6.1" />
    <PackageReference Include="OpenTK" Version="4.7.6" />
    <PackageReference Include="System.Drawing.Common" Version="10.0.3" />
  </ItemGroup>
</Project>
